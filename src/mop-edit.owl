# Object Property: obo:MOP_0000769 (is_catalysis_of)

AnnotationAssertion(Annotation(oboInOwl:hasDbXref "https://orcid.org/0000-0001-5985-7429") obo:IAO_0000115 obo:MOP_0000769 "x is_catalysis_of y if and only if x positively_regulates y and the positive regulation works by providing a more kinetically-favourable route across the energy landscape from the reactants of y to the products of y.")
AnnotationAssertion(oboInOwl:id obo:MOP_0000769 "MOP:0000769")
AnnotationAssertion(rdfs:label obo:MOP_0000769 "is_catalysis_of")
SubObjectPropertyOf(obo:MOP_0000769 obo:RO_0002213)

# Object Property: obo:RO_0002213 (positively_regulates)

AnnotationAssertion(obo:IAO_0000115 obo:RO_0002213 "x positively regulates y if and only if the progression of x increases the frequency, rate or extent of y")
AnnotationAssertion(oboInOwl:id obo:RO_0002213 "RO:0002213")
AnnotationAssertion(rdfs:label obo:RO_0002213 "positively_regulates")



