# Class: obo:MOP_0000714 (ligand exchange reaction)

AnnotationAssertion(Annotation(oboInOwl:hasDbXref "https://doi.org/10.1093/oso/9780195301007.003.0005"^^xsd:anyURI) Annotation(rdfs:comment "A definition of this term in the Gold Book was not yet available at the time of addition. However, inclusion in the Gold Book was requested in October 2021.") obo:IAO_0000115 obo:MOP_0000714 "A ligand exchange reaction is a molecular process, in which one or more ligands around a metal ion are replaced by other ligands without changing the oxidation state of the metal atom.")
AnnotationAssertion(oboInOwl:created_by obo:MOP_0000714 <http://orcid.org/0000-0002-4378-6061>)
AnnotationAssertion(oboInOwl:creation_date obo:MOP_0000714 "2021-11-03T09:13:45Z"^^xsd:dateTime)
AnnotationAssertion(oboInOwl:hasExactSynonym obo:MOP_0000714 "ligand substitution reaction")
AnnotationAssertion(oboInOwl:id obo:MOP_0000714 "MOP:0000714")
AnnotationAssertion(rdfs:comment obo:MOP_0000714 "Typically, weakly bound ligands are replaced by more strongly bound ones, so that the resulting complex becomes thermodynamically more stable.")
AnnotationAssertion(rdfs:label obo:MOP_0000714 "ligand exchange reaction"@en)
SubClassOf(obo:MOP_0000714 obo:MOP_0000543)
SubClassOf(obo:MOP_0000714 ObjectSomeValuesFrom(obo:BFO_0000057 obo:CHEBI_52214))

# Class: obo:MOP_0000715 (trimerization)

AnnotationAssertion(Annotation(oboInOwl:hasDbXref "https://en.wiktionary.org/wiki/trimerization"^^xsd:anyURI) obo:IAO_0000115 obo:MOP_0000715 "The formation of a trimer from three molecular subunits.")
AnnotationAssertion(obo:IAO_0000116 obo:MOP_0000715 "The GO class \"protein trimerization\" (https://purl.obolibrary.org/obo/GO_0070206) would actually be a subclass of \"trimerization\" according to the definition provided here. However, for the reason of not wanting to inject this subclassOf axiom into GO, we decided to not assert this in MOP as of yet. Further discussion is needed with the GO and/or OBO team to see how this GO class can be integrated.")
AnnotationAssertion(dc:creator obo:MOP_0000715 <http://orcid.org/0000-0002-4378-6061>)
AnnotationAssertion(dc:date obo:MOP_0000715 "2022-02-01T09:40:48Z"^^xsd:dateTime)
AnnotationAssertion(oboInOwl:id obo:MOP_0000715 "MOP:0000715")
AnnotationAssertion(rdfs:label obo:MOP_0000715 "trimerization"@en)
AnnotationAssertion(rdfs:seeAlso obo:MOP_0000715 <https://github.com/rsc-ontologies/rxno/issues/45>)
AnnotationAssertion(rdfs:seeAlso obo:MOP_0000715 <https://github.com/rsc-ontologies/rxno/pull/46#issuecomment-1124151946>)
SubClassOf(obo:MOP_0000715 obo:MOP_0000543)

